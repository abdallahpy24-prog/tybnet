    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.58.1",
    "sharp": "^0.34.2",
