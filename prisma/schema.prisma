generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum ProviderType {
  DOCTOR
  DENTIST
}

enum SpecialtyFor {
  DOCTOR
  DENTIST
  BOTH
}

enum PublishStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum AppointmentStatus {
  NEW
  FOLLOWING
  COMPLETED
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  username     String     @unique
  passwordHash String
  role         Role       @default(ADMIN)
  isActive     Boolean    @default(true)
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([role, isActive])
  @@index([createdAt])
}

model Governorate {
  id         String     @id @default(cuid())
  name       String     @unique
  slug       String     @unique
  sortOrder  Int        @default(0)
  isActive   Boolean    @default(true)
  areas      Area[]
  providers  Provider[]
  pharmacies Pharmacy[]
  labs       Lab[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([isActive, sortOrder])
}

model Area {
  id            String      @id @default(cuid())
  name          String
  slug          String
  governorateId String
  governorate   Governorate @relation(fields: [governorateId], references: [id])
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)
  providers     Provider[]
  pharmacies    Pharmacy[]
  labs          Lab[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([governorateId, name])
  @@unique([governorateId, slug])
  @@index([governorateId])
  @@index([governorateId, isActive, sortOrder])
}

model Specialty {
  id        String       @id @default(cuid())
  name      String
  slug      String
  forType   SpecialtyFor @default(DOCTOR)
  icon      String?
  isActive  Boolean      @default(true)
  providers Provider[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, forType])
  @@unique([slug, forType])
  @@index([forType, isActive])
}

model Provider {
  id            String        @id @default(cuid())
  type          ProviderType
  name          String
  slug          String        @unique
  titlePrefix   String        @default("د.")
  specialtyId   String?
  specialty     Specialty?    @relation(fields: [specialtyId], references: [id])
  governorateId String
  governorate   Governorate   @relation(fields: [governorateId], references: [id])
  areaId        String
  area          Area          @relation(fields: [areaId], references: [id])
  bio           String?
  address       String?
  phone         String?
  whatsapp      String?
  instagramUrl  String?
  imageUrl      String?
  workingHours  String?
  status        PublishStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  sortOrder     Int           @default(0)
  bookingPoints Int           @default(0)
  offers        Offer[]
  appointments  Appointment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([type, status, isFeatured])
  @@index([type, status, isFeatured, bookingPoints])
  @@index([governorateId, areaId, specialtyId])
  @@index([status, sortOrder])
  @@index([createdAt])
}

model Pharmacy {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  governorateId String
  areaId        String
  governorate   Governorate   @relation(fields: [governorateId], references: [id])
  area          Area          @relation(fields: [areaId], references: [id])
  address       String?
  phone         String?
  whatsapp      String?
  imageUrl      String?
  workingHours  String?
  status        PublishStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, governorateId, areaId])
  @@index([status, isFeatured])
  @@index([createdAt])
}

model Lab {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  governorateId String
  areaId        String
  governorate   Governorate   @relation(fields: [governorateId], references: [id])
  area          Area          @relation(fields: [areaId], references: [id])
  services      String?
  address       String?
  phone         String?
  whatsapp      String?
  imageUrl      String?
  workingHours  String?
  status        PublishStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, governorateId, areaId])
  @@index([status, isFeatured])
  @@index([createdAt])
}

model Offer {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  description  String?
  imageUrl     String?
  discountText String?
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean   @default(true)
  providerId   String?
  provider     Provider? @relation(fields: [providerId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive, endsAt])
  @@index([providerId])
  @@index([createdAt])
}

model Appointment {
  id            String            @id @default(cuid())
  providerId    String?
  provider      Provider?         @relation(fields: [providerId], references: [id])
  patientName   String
  patientPhone  String
  note          String?
  preferredDate DateTime?
  status        AppointmentStatus @default(NEW)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([providerId])
  @@index([status, createdAt])
  @@index([preferredDate])
}

model Media {
  id        String   @id @default(cuid())
  fileName  String
  url       String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([mimeType])
}

model Setting {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}