# =====================================================
# TibNet / طب نت - Environment Variables Example
# =====================================================
# انسخ هذا الملف إلى .env للتشغيل المحلي
# لا ترفع ملف .env الحقيقي إلى GitHub أبداً

# =====================================================
# Database - PostgreSQL / Supabase
# =====================================================
# Local example:
# DATABASE_URL="postgresql://tibnet:tibnet123@localhost:5433/tibnet?schema=public"
# DIRECT_URL="postgresql://tibnet:tibnet123@localhost:5433/tibnet?schema=public"

# Supabase example:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# =====================================================
# Auth.js / NextAuth
# =====================================================
# Generate with:
# openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"

# Local:
AUTH_URL="http://localhost:3000"

# Production example:
# AUTH_URL="https://tybnet.com"

# =====================================================
# Public Site URL
# =====================================================
# Local:
PUBLIC_SITE_URL="http://localhost:3000"

# Production example:
# PUBLIC_SITE_URL="https://tybnet.com"

# =====================================================
# Initial Admin User - Used by prisma db seed
# =====================================================
ADMIN_NAME="Admin User"
ADMIN_EMAIL="admin@example.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# =====================================================
# Uploads
# =====================================================
# Options:
# local     = local uploads, only for development
# supabase  = recommended for production on Vercel
UPLOAD_PROVIDER="supabase"

# =====================================================
# Supabase Storage
# =====================================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="tibnet-uploads"

# =====================================================
# Public Contact Info
# =====================================================
NEXT_PUBLIC_CONTACT_WHATSAPP=""
NEXT_PUBLIC_CONTACT_EMAIL=""